                                <td>Recalculated Expected Credit Loss models across 982 member profiles</td>
                                <td><span class="badge bg-pass">Verified Safe</span></td>
                            </tr>
                            <tr>
                                <td><code>AUD-8842-A</code></td>
                                <td>2026-05-19 16:45</td>
                                <td>Internal Auditor (Sarah W.)</td>
                                <td>General Ledger Override</td>
                                <td>Adjusted operating reserve thresholds to align with year-end regulatory requirements</td>
                                <td><span class="badge bg-pass">Approved</span></td>
                            </tr>
                            <tr>
                                <td><code>AUD-8711-K</code></td>
                                <td>2026-05-15 09:00</td>
                                <td>Compliance Manager</td>
