                                <td class="num-col">$1,180,000.00</td>
                                <td class="num-col">94.48%</td>
                                <td><span style="color:var(--success); font-weight:600;">Monitor Account</span></td>
                            </tr>
                            <tr>
                                <td><span class="badge bg-review">Stage 2: Watchlist</span></td>
                                <td>Delinquent (31 - 90 Days)</td>
                                <td class="num-col">$46,200.00</td>
                                <td class="num-col">3.70%</td>
                                <td><span style="color:var(--warning); font-weight:600;">Active Outbound Push</span></td>
                            </tr>
                            <tr>
