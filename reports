                            <td>Net Interest Spread / Operating Margin</td>
                            <td class="num-col" id="lblNetMargin">$0.00</td>
                        </tr>
                        <tr>
                            <td>Less: Non-Performing Loan Loss Provisions Allocation</td>
                            <td class="num-col" id="lblProvision">($0.00)</td>
                        </tr>
                        <tr>
                            <td>Less: General Administrative Overhead & Personnel Expenses</td>
                            <td class="num-col" id="lblOpex">($0.00)</td>
                        </tr>
                        <tr style="background:#f1f5f9; font-weight:700;">
                            <td>Net Earnings Before Taxation (EBT)</td>
                            <td class="num-col" id="lblEBT">$0.00</td>
                        </tr>
                        <tr>
                            <td>Provision for National Corporate Income Tax</td>
                            <td class="num-col" id="lblTax">($0.00)</td>
                        </tr>
                        <tr style="background:#cbd5e1; font-weight:800; font-size:0.95rem;">
                            <td>Retained Net Income / Profit Surplus for Distribution</td>
                            <td class="num-col" id="lblNetProfit" style="color:var(--success)">$0.00</td>
                        </tr>
