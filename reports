</div>

<script>
    // System Lifecycle Startup
    window.addEventListener('DOMContentLoaded', () => {
        recalculatePnLStatement();
        
        // Dynamic Date Injection matching execution context
        const today = new Date();
        const options = { year: 'numeric', month: 'long', day: 'numeric' };
        document.getElementById('memoDate').innerText = today.toLocaleDateString('en-US', options);
    });

    // Tab Interface Swapping Controller
    function switchTab(targetId) {
        document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
        document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));
        
        document.getElementById(targetId).classList.add('active');
        event.currentTarget.classList.add('active');
    }

    // GAAP Financial Calculation Modeling Engine
    function recalculatePnLStatement() {
        // Fetch raw slider/input user parameters
        let grossRev = parseFloat(document.getElementById('paramRevenue').value) || 0;
        let interestExp = parseFloat(document.getElementById('paramInterest').value) || 0;
        let provisionExp = parseFloat(document.getElementById('paramProvision').value) || 0;
        let opexExp = parseFloat(document.getElementById('paramOpex').value) || 0;
        let taxRate = parseFloat(document.getElementById('paramTax').value) || 0;

        // Perform programmatic baseline calculations
        let netMargin = grossRev - interestExp;
        let ebt = netMargin - provisionExp - opexExp;
        let taxCharged = ebt > 0 ? (ebt * (taxRate / 100)) : 0;
        let netProfit = ebt - taxCharged;

        // Hydrate GUI table data fields cleanly formatted
        document.getElementById('lblGrossRev').innerText = formatCurrency(grossRev);
        document.getElementById('lblInterestExp').innerText = "(" + formatCurrency(interestExp) + ")";
        document.getElementById('lblNetMargin').innerText = formatCurrency(netMargin);
        document.getElementById('lblProvision').innerText = "(" + formatCurrency(provisionExp) + ")";
        document.getElementById('lblOpex').innerText = "(" + formatCurrency(opexExp) + ")";
        
        let ebtField = document.getElementById('lblEBT');
        ebtField.innerText = formatCurrency(ebt);
        if (ebt < 0) ebtField.className = "num-col negative-val";
        else ebtField.className = "num-col";

        document.getElementById('lblTax').innerText = "(" + formatCurrency(taxCharged) + ")";
        
        let profitField = document.getElementById('lblNetProfit');
        profitField.innerText = formatCurrency(netProfit);
        if (netProfit < 0) {
            profitField.className = "num-col negative-val";
            profitField.style.color = "var(--danger)";
        } else {
            profitField.className = "num-col";
            profitField.style.color = "var(--success)";
        }

        // Keep Board Memorandum content updated dynamically
        document.getElementById('memoSurplus').innerText = formatCurrency(netProfit);
    }

    // Helper Currency Structural Formatter
    function formatCurrency(val) {
        return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(val);
    }
</script>
